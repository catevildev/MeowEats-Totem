{
  "name": "workspace",
  "version": "0.0.0",
  "license": "MIT",
  "scripts": {
    "preinstall": "node scripts/preinstall.cjs",
    "stack:up": "node scripts/stack-up.mjs",
    "stack:up:fresh": "node scripts/stack-up-fresh.mjs",
    "stack:down": "docker compose down",
    "stack:prod": "node scripts/stack-prod.mjs",
    "stack:prod:down": "docker compose -f docker-compose.prod.yml down",
    "dev:api": "pnpm --filter @workspace/api-server run dev",
    "dev:kiosk": "pnpm --filter @workspace/kiosk run dev",
    "build": "pnpm run typecheck && pnpm -r --if-present run build",
    "typecheck:libs": "tsc --build",
    "typecheck": "pnpm run typecheck:libs && pnpm -r --filter \"./artifacts/**\" --filter \"./scripts\" --if-present run typecheck"
  },
  "private": true,
  "devDependencies": {
    "typescript": "~5.9.2",
    "prettier": "^3.8.1"
  }
}
