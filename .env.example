# =============================================================================
# Copie para .env (não commitar .env com segredos reais)
# =============================================================================

# --- Dev local (docker-compose.yml completo com kiosk) ---
DATABASE_URL=mysql://meoweats:meoweats@127.0.0.1:6010/meoweats
PORT=6005

# --- Produção Lightsail (docker-compose.prod.yml) ---
MYSQL_ROOT_PASSWORD=troque-root-forte
MYSQL_PASSWORD=troque-senha-app
# URLs do front na Vercel (sem espaços), ex.:
# CORS_ORIGIN=https://meoweats.vercel.app,https://meoweats-git-main-seu-user.vercel.app
CORS_ORIGIN=

# PlugNotas (opcional)
PLUGNOTAS_BASE_URL=https://api.sandbox.plugnotas.com.br
PLUGNOTAS_API_KEY=
PLUGNOTAS_AMBIENTE=sandbox

# =============================================================================
# Vercel → Project → Settings → Environment Variables (Build + Production)
# =============================================================================
# VITE_API_URL=https://SEU_IP_LIGHTSAIL:6005
# (sem barra no final; use HTTPS se tiver proxy/SSL na frente da API)
